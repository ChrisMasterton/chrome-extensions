{
  "manifest_version": 3,
  "name": "Element Picker for Claude",
  "description": "Build debug bundles with stable locators, saved screenshot crops, scroll diagnostics, and repro hints",
  "version": "1.3",
  "permissions": ["activeTab", "scripting", "clipboardWrite", "downloads"],
  "action": {
    "default_title": "Pick Element",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
